# ── Telegram ──────────────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# ── OpenAI ────────────────────────────────────────────────────────────────────
# Used for Whisper voice transcription (always required).
# Also used as vision provider when AI_PROVIDER=openai.
OPENAI_API_KEY=your_openai_api_key_here

# Vision model for OpenAI provider. Must support vision (image input).
#   gpt-4o-mini  — cheap, good quality (recommended)
#   gpt-4o       — best quality, higher cost
OPENAI_MODEL=gpt-4o-mini

# ── OpenRouter ────────────────────────────────────────────────────────────────
# Used as vision provider when AI_PROVIDER=openrouter (or as fallback).
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Vision model for OpenRouter provider. Must support vision (image input).
#   google/gemini-2.0-flash-lite              — cheapest (~$0.075/1M tokens)
#   google/gemini-flash-1.5                   — similar price, slightly better
#   meta-llama/llama-3.2-90b-vision-instruct  — very capable (~$0.35/1M)
#   anthropic/claude-3.5-haiku                — best quality (~$0.80/1M)
OPENROUTER_MODEL=google/gemini-2.0-flash-lite

# ── Provider selection ────────────────────────────────────────────────────────
# Which provider to use first for photo analysis.
# On 402 (no credits) or 429 (rate limit) the other provider is tried automatically.
#   openai      — use OpenAI first, OpenRouter as fallback
#   openrouter  — use OpenRouter first, OpenAI as fallback
AI_PROVIDER=openai

# ── Pricing (USD) ─────────────────────────────────────────────────────────────
# Vision model token prices (per 1 million tokens).
# Update when you change the model. Current defaults match gpt-4o-mini.
OPENAI_PRICE_INPUT_PER_1M=0.15
OPENAI_PRICE_OUTPUT_PER_1M=0.60

# Current defaults match google/gemini-2.0-flash-lite.
OPENROUTER_PRICE_INPUT_PER_1M=0.075
OPENROUTER_PRICE_OUTPUT_PER_1M=0.30

# Whisper: price per minute of audio transcribed.
WHISPER_PRICE_PER_MINUTE=0.006

# ── Stats access ──────────────────────────────────────────────────────────────
# Comma-separated Telegram user IDs allowed to call /stats.
# Find your ID via @userinfobot in Telegram.
STATS_USER_IDS=381764678
