# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# OpenAI API key (for Whisper voice transcription)
OPENAI_API_KEY=your_openai_api_key_here

# OpenRouter API key (for vision model)
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Vision model on OpenRouter (cheap + capable, supports vision)
# Options:
#   google/gemini-2.0-flash-lite  — cheapest, good quality (~$0.075/1M tokens)
#   google/gemini-flash-1.5       — slightly better, same price
#   meta-llama/llama-3.2-90b-vision-instruct — very capable, ~$0.35/1M tokens
#   anthropic/claude-3.5-haiku    — best quality, ~$0.80/1M tokens
OPENROUTER_MODEL=google/gemini-2.0-flash-lite
